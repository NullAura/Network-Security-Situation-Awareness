[Unit]
Description=Honeypot Flink realtime stream job
After=network-online.target flink-standalone.service
Wants=network-online.target flink-standalone.service

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
Environment=FLINK_HOME=/opt/flink
ExecStart=/opt/honeypot-flink/honeypot_flink_submit.sh start
ExecStop=/opt/honeypot-flink/honeypot_flink_submit.sh stop

[Install]
WantedBy=multi-user.target
